install.packages(gt)
install.packages("gt")
library(gt)
library(dplyr)
?gt()
tp53_cases <- c("N012", "N017", "N077", "N141", "N186", "N206",
"S004", "S016", "S026", "S033", "S036", "S074",
"S075", "S089", "S116", "S155", "S159", "S166",
"S194", "S218", "S008", "S048", "S145", "S220", "S235")
library(gt)
library(dplyr)
biobank_data_reshape %>%
filter(study_number %in% tp53_cases) %>%
select(
study_number,
gender,
who_diagnosis,
ipss_r_diagnosis,
karyotype,
reason_for_termination,
MRD_interpretation,
GVHD,
`TP53 multi hit`,
donor_type,
`Steroids 3 months`,
`Steroids 6 months`,
`Steroids 12 months`,
`GVHD profylaxis 3 months`,
`GVHD profylaxis 6 months`,
`GVHD profylaxis 12 months`
) %>%
gt() %>%
tab_header(
title = "TP53 Positive Cases"
)
biobank_data %>%
filter(study_number %in% tp53_cases) %>%
select(
study_number,
gender,
who_diagnosis,
ipss_r_diagnosis,
karyotype,
reason_for_termination,
MRD_interpretation,
GVHD,
`TP53 multi hit`,
donor_type,
`Steroids 3 months`,
`Steroids 6 months`,
`Steroids 12 months`,
`GVHD profylaxis 3 months`,
`GVHD profylaxis 6 months`,
`GVHD profylaxis 12 months`
) %>%
gt() %>%
tab_header(
