col = "black",
alpha = 0.75,
width = 0.8
) +
swimmer_points(
df_points = tp53_df,
id = "study_number",
time = "time"
) +
swimmer_arrows(
df_arrows = tp53_df,
id = "study_number",
arrow_start = "end_event",
cont = "two_years_passed",
name_col = "two_years_passed",
show.legend = FALSE,
type = "open",
cex = 1,
arrow_positions = c(25, 150)
) +
swimmer_points(
df_points = tp53_df[!is.na(tp53_df$death_date), ],
id = "study_number",
time = "death_dot_time",  # shift right
shape = 21,
size = 3,
fill = "black",
col = "black",
alpha = 1,
adj.y = 0
) +
ggplot2::ylab("Days from transplantation") +
ggplot2::xlab("Patient ID") +
ggplot2::ggtitle("Patients with TP53 mutations") +
ggplot2::theme_classic()
swimmer_plot
